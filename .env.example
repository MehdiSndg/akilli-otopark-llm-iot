# Bu dosyayı ".env" olarak kopyala ve değerleri doldur.
# .env dosyası git'e GİRMEZ (.gitignore'da).

# --- LLM sağlayıcı seçimi ---
# gemini | anthropic | openai | ollama
LLM_PROVIDER=gemini
# İstersen model adını elle ezebilirsin (boş bırakırsan config.py varsayılanı):
# LLM_MODEL=gemini-2.0-flash

# Açıklama için 2. LLM çağrısı yapılsın mı?
# true  -> daha akıcı doğal dil (istek başına 2 çağrı)
# false -> tek çağrı + zengin şablon açıklama; Gemini 20/gün kotası 2 kat dayanır
# (Kotanın çabuk dolduğu demolarda false önerilir.)
LLM_EXPLAIN=true

# --- API anahtarları (yalnızca kullandığın sağlayıcınınkini doldur) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Ollama (yerel, ücretsiz alternatif) ---
OLLAMA_HOST=http://localhost:11434

# --- MQTT broker ---
MQTT_HOST=localhost
MQTT_PORT=1883
